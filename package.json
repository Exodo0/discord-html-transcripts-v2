{
  "name": "discord-html-transcripts-v2",
  "version": "3.3.6",
  "description": "A nicely formatted html transcript generator for discord.js.",
  "main": "dist/index.js",
  "homepage": "https://github.com/Exodo0/discord-html-transcripts-v2",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "bot:example": "ts-node -P BotExample/tsconfig.json BotExample/index.ts",
    "test:typescript": "ts-node ./tests/generate.ts",
    "test:send-components-v2": "ts-node ./tests/components-v2-send.ts",
    "lint": "prettier --write --cache . && eslint --cache --fix .",
    "typecheck": "tsc -p tsconfig.eslint.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Exodo0/discord-html-transcripts-v2.git"
  },
  "keywords": [
    "discord.js",
    "discord.js-transcripts",
    "discord.js-html-transcripts",
    "html-transcripts",
    "discord-html-transcripts",
    "discord-html-transcripts-v2",
    "discord-transcripts"
  ],
  "author": "Exodo0",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "debug": "^4.4.3",
    "discord.js": "14.26.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@derockdev/discord-components-core": "^3.6.1",
    "@derockdev/discord-components-react": "^3.6.1",
    "discord-markdown-parser": "~1.3.1",
    "simple-markdown": "^0.7.3",
    "twemoji": "^14.0.2",
    "undici": "^8.1.0"
  },
  "peerDependencies": {
    "discord.js": "^14.25.1 || ^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
      }
    }
  },
  "packageManager": "pnpm@10.11.0"
}
