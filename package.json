{
  "name": "discord-html-transcripts-v2",
  "version": "4.0.2",
  "description": "A nicely formatted HTML transcript generator for discord.js — supports classic messages, embeds, and V2 Components (ContainerBuilder).",
  "homepage": "https://github.com/Exodo0/discord-html-transcripts-v2",
  "license": "Apache-2.0",
  "author": "Exodo0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Exodo0/discord-html-transcripts-v2.git"
  },
  "keywords": [
    "discord.js",
    "discord-transcripts",
    "discord-html-transcripts",
    "discord-html-transcripts-v2",
    "html-transcripts",
    "components-v2"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "prettier --write --cache . && eslint --cache --fix .",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bot:example": "ts-node -P BotExample/tsconfig.json BotExample/index.ts"
  },
  "dependencies": {
    "@derockdev/discord-components-core": "3.6.1",
    "@derockdev/discord-components-react": "3.6.1",
    "debug": "4.4.3",
    "discord-markdown-parser": "~1.3.1",
    "simple-markdown": "0.7.3",
    "twemoji": "14.0.2",
    "undici": "8.1.0"
  },
  "peerDependencies": {
    "discord.js": "14.25.1 || 15.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@eslint/js": "latest",
    "@types/debug": "latest",
    "@types/node": "25.6.0",
    "@types/react": "18.3.26",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitest/coverage-v8": "4.1.5",
    "discord.js": "14.26.3",
    "dotenv": "17.4.2",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "pretty-quick": "4.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.34.5",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.11.0"
}
